{
  "name": "@keg-hub/file-lib",
  "version": "0.0.1",
  "description": "Helpers to interact with the host machines file system",
  "repository": {
    "url": "git+https://github.com/KegHub/keg-cli.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/KegHub/keg-cli/issues"
  },
  "homepage": "https://github.com/KegHub/keg-cli#readme",
  "main": "index.js",
  "author": "Lance Tipton",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "exit 0",
    "clean": "yarn clean:nm",
    "clean:cache": "yarn cache clean",
    "clean:full": "yarn clean; yarn clean:cache",
    "clean:install": "yarn clean:full; yarn install --force",
    "clean:nm": "rimraf yarn.lock; rimraf package.lock; rimraf node_modules",
    "format": "exit 0",
    "test": "NODE_ENV=test jest --no-cache --verbose",
    "test:reports": "NODE_ENV=test jest --no-cache --verbose --coverage"
  },
  "dependencies": {
    "@keg-hub/jsutils": "8.7.0",
    "app-root-path": "3.0.0"
  },
  "devDependencies": {
    "jest": "26.6.3",
    "rimraf": "3.0.2"
  }
}
